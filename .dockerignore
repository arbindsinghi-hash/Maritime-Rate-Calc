# ==========================
# MRCA AI Tariff — Backend Docker build context
# ==========================

# ---- Version control ----
.git
.gitignore

# ---- Python virtual env ----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# ---- Frontend (not needed in backend image) ----
frontend/node_modules/
frontend/.next/
frontend/dist/
frontend/out/

# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# ---- Test / CI artifacts ----
.pytest_cache/
htmlcov/
.coverage
coverage.xml
.ruff_cache/

# ---- Data volumes (mounted at runtime) ----
storage/pdfs/
storage/faiss/
storage/audit/

# ---- Output artifacts ----
output/

# ---- Docs / planning (not needed in image) ----
docs/
*.md
!requirements.txt

# ---- Secrets ----
.env
.env.local
.env.*.local

# ---- Docker ----
docker-compose.yml
Makefile
