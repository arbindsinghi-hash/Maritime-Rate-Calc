# ==============================================================================
# MRCA AI Tariff — Environment Configuration (TEMPLATE)
# ==============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file with real secrets.
# ==============================================================================

# ---- Gemini 2.5 Pro (primary VL extractor for ingestion) ----
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ---- Gemini 2.5 Flash (chat mode extraction) ----
# Used for NL → structured extraction in the /chat endpoint.
# Users can also provide their own key via the UI if this is not set.
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ---- LLM / Chat (gpt-oss:120b) ----
LLM_API_BASE=https://your-openshift-cluster/api/v1
LLM_API_KEY=your-jwt-token-here
LLM_MODEL=gpt-oss:120b

# ---- Embedding Model ----
EMBEDDING_API_BASE=https://your-openshift-cluster/api/v1
EMBEDDING_API_KEY=your-jwt-token-here
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# ---- Audit Store (JSONL file-based, no external DB needed) ----
AUDIT_LOG_DIR=storage/audit

# ---- Developer Prompt Panel ----
# Set to true to enable the Prompts tab in the UI showing all LLM interactions
# (user query, system prompt, raw response, parsed result/error).
# Useful for debugging and development. Keep false in production.
ENABLE_PROMPT_PANEL=true

# ---- Storage Paths ----
PDF_DIR=storage/pdfs
YAML_DIR=storage/yaml
FAISS_DIR=storage/faiss

# ---- LLM Behaviour ----
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
